{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/razterizer/forge/main/schemas/forge.recipe.schema.json",
  "title": "Forge recipe",
  "description": "Describes a C++ project built and packaged by Forge.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "sources"
  ],
  "properties": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "type",
        "cpp_std"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$",
          "description": "Package and output artifact name."
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
          "description": "Semantic package version. Artifact build metadata belongs in build.number."
        },
        "type": {
          "type": "string",
          "enum": [
            "executable",
            "static_library",
            "header_only"
          ],
          "description": "Kind of project Forge builds and packages."
        },
        "cpp_std": {
          "type": "integer",
          "enum": [
            11,
            14,
            17,
            20,
            23,
            26
          ],
          "description": "Required C++ language standard."
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional artifact build number, represented as SemVer build metadata."
        }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "paths"
      ],
      "properties": {
        "paths": {
          "$ref": "#/$defs/projectPaths",
          "description": "C++ compilation units belonging to the project."
        },
        "public_headers": {
          "$ref": "#/$defs/publicHeaders"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "const": "executable"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "sources": {
            "type": "object",
            "properties": {
              "paths": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "const": "static_library"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "sources": {
            "type": "object",
            "required": [
              "public_headers"
            ],
            "properties": {
              "paths": {
                "type": "array",
                "minItems": 1
              },
              "public_headers": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "const": "header_only"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "sources": {
            "type": "object",
            "required": [
              "public_headers"
            ],
            "properties": {
              "paths": {
                "type": "array",
                "maxItems": 0
              },
              "public_headers": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$",
      "description": "A relative path that remains inside the project."
    },
    "projectPaths": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projectPath"
      },
      "uniqueItems": true
    },
    "publicHeaders": {
      "type": "array",
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/projectPath"
          },
          {
            "type": "string",
            "pattern": "^include/"
          }
        ]
      },
      "uniqueItems": true,
      "description": "Headers exposed to consumers. Paths must remain under include/."
    }
  }
}
