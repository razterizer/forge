{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/razterizer/forge/main/schemas/forge.recipe.schema.json",
  "title": "Forge recipe",
  "description": "Describes a C++ project built, imported, and packaged by Forge.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project"
  ],
  "properties": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$",
          "description": "Package and output artifact name."
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
          "description": "Semantic package version. Artifact build metadata belongs in build.number."
        },
        "type": {
          "type": "string",
          "enum": [
            "executable",
            "static_library",
            "dynamic_library",
            "shared_library",
            "imported_library",
            "header_only"
          ],
          "description": "Kind of project Forge builds or imports and packages. shared_library is a legacy alias for dynamic_library."
        },
        "cpp_std": {
          "type": "integer",
          "enum": [
            11,
            14,
            17,
            20,
            23,
            26
          ],
          "description": "C++ language standard Forge uses to build this project. Compiled boxes record it separately as toolchain metadata for compatibility checks."
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional artifact build number, represented as SemVer build metadata."
        },
        "defines": {
          "$ref": "#/$defs/compileDefinitions",
          "description": "Private preprocessor definitions applied when compiling the project."
        },
        "macos_system_include_dirs": {
          "$ref": "#/$defs/paths",
          "description": "macOS-only external include search directories passed to CMake as SYSTEM includes."
        },
        "linux_system_include_dirs": {
          "$ref": "#/$defs/paths",
          "description": "Linux-only external include search directories passed to CMake as SYSTEM includes."
        },
        "windows_system_include_dirs": {
          "$ref": "#/$defs/paths",
          "description": "Windows-only external include search directories passed to CMake as SYSTEM includes."
        },
        "macos_system_library_dirs": {
          "$ref": "#/$defs/paths",
          "description": "macOS-only external library search directories passed to CMake."
        },
        "linux_system_library_dirs": {
          "$ref": "#/$defs/paths",
          "description": "Linux-only external library search directories passed to CMake."
        },
        "windows_system_library_dirs": {
          "$ref": "#/$defs/paths",
          "description": "Windows-only external library search directories passed to CMake."
        },
        "macos_frameworks": {
          "$ref": "#/$defs/linkNames"
        },
        "macos_libraries": {
          "$ref": "#/$defs/linkNames"
        },
        "linux_libraries": {
          "$ref": "#/$defs/linkNames"
        },
        "windows_libraries": {
          "$ref": "#/$defs/linkNames"
        }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "paths"
      ],
      "properties": {
        "paths": {
          "$ref": "#/$defs/projectPaths",
          "description": "C++ compilation units belonging to the project."
        },
        "public_headers": {
          "$ref": "#/$defs/publicHeaders"
        },
        "include_dirs": {
          "$ref": "#/$defs/projectPaths",
          "description": "Private project-relative include search directories."
        }
      }
    },
    "target": {
      "type": "object",
      "description": "Named build targets. Use instead of the legacy project.type and sources sections.",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "cpp_std",
          "sources"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "executable",
              "static_library",
              "dynamic_library",
              "shared_library",
              "header_only"
            ],
            "description": "Kind of named target Forge builds."
          },
          "cpp_std": {
            "type": "integer",
            "enum": [11, 14, 17, 20, 23, 26],
            "description": "C++ language standard Forge uses to build this target."
          },
          "sources": {
            "$ref": "#/$defs/projectPaths",
            "description": "C++ compilation units belonging to this target."
          },
          "public_headers": {
            "$ref": "#/$defs/publicHeaders"
          },
          "include_dirs": {
            "$ref": "#/$defs/projectPaths",
            "description": "Private project-relative include search directories."
          },
          "macos_system_include_dirs": {
            "$ref": "#/$defs/paths",
            "description": "macOS-only external include search directories passed to CMake as SYSTEM includes."
          },
          "linux_system_include_dirs": {
            "$ref": "#/$defs/paths",
            "description": "Linux-only external include search directories passed to CMake as SYSTEM includes."
          },
          "windows_system_include_dirs": {
            "$ref": "#/$defs/paths",
            "description": "Windows-only external include search directories passed to CMake as SYSTEM includes."
          },
          "macos_system_library_dirs": {
            "$ref": "#/$defs/paths",
            "description": "macOS-only external library search directories passed to CMake."
          },
          "linux_system_library_dirs": {
            "$ref": "#/$defs/paths",
            "description": "Linux-only external library search directories passed to CMake."
          },
          "windows_system_library_dirs": {
            "$ref": "#/$defs/paths",
            "description": "Windows-only external library search directories passed to CMake."
          },
          "defines": {
            "$ref": "#/$defs/compileDefinitions",
            "description": "Preprocessor definitions applied when compiling this target."
          },
          "runtime_files": {
            "$ref": "#/$defs/runtimeFiles",
            "description": "Project-relative runtime assets. Executable target assets are staged beside that executable; library target assets are exported to consumers and optionally mapped to a different destination."
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$"
            },
            "uniqueItems": true,
            "description": "Named library targets from this recipe linked into this target."
          },
          "macos_frameworks": {
            "$ref": "#/$defs/linkNames"
          },
          "macos_libraries": {
            "$ref": "#/$defs/linkNames"
          },
          "linux_libraries": {
            "$ref": "#/$defs/linkNames"
          },
          "windows_libraries": {
            "$ref": "#/$defs/linkNames"
          },
          "test": {
            "type": "boolean",
            "description": "Marks an executable target for forge test."
          }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "description": "Local project, pinned Git project, local cbox, downloadable cbox, or GitHub Release cbox dependencies.",
      "propertyNames": {
        "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Path to a local Forge project, relative to this recipe or absolute."
          },
          "box": {
            "type": "string",
            "minLength": 1,
            "description": "Path to a local cbox file, relative to this recipe or absolute."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "minLength": 1,
            "description": "URL of a downloadable cbox file."
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$",
            "description": "Expected SHA-256 checksum of the downloaded cbox file."
          },
          "github": {
            "type": "string",
            "pattern": "^[^/\\\\]+/[^/\\\\]+$",
            "description": "GitHub repository containing Forge release assets, in owner/repository form."
          },
          "package": {
            "type": "string",
            "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$",
            "description": "Published package identity used for the GitHub Release cbox filename. Defaults to the dependency name."
          },
          "version": {
            "type": "string",
            "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+build\\.(0|[1-9][0-9]*))?$",
            "description": "Packaged dependency version to resolve from the GitHub release."
          },
          "git": {
            "type": "string",
            "minLength": 1,
            "description": "Git repository URL or path containing a Forge source project."
          },
          "commit": {
            "type": "string",
            "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$",
            "description": "Exact full Git commit ID to checkout."
          },
          "component": {
            "type": "string",
            "minLength": 1,
            "description": "Named library component to consume from a multi-component cbox."
          },
          "variant": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+$",
            "description": "Named GitHub Release cbox variant to consume, such as openal or applaudio."
          },
          "targets": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/platformTarget"
            },
            "uniqueItems": true,
            "description": "Optional platform targets that enable this dependency. Omit to use the dependency on every target."
          }
        },
        "oneOf": [
          {
            "required": ["path", "github", "version"],
            "not": {
              "anyOf": [
                { "required": ["box"] },
                { "required": ["url"] },
                { "required": ["sha256"] },
                { "required": ["git"] },
                { "required": ["commit"] }
              ]
            }
          },
          {
            "required": ["path"],
            "not": {
              "anyOf": [
                { "required": ["box"] },
                { "required": ["url"] },
                { "required": ["sha256"] },
                { "required": ["github"] },
                { "required": ["package"] },
                { "required": ["version"] },
                { "required": ["git"] },
                { "required": ["commit"] },
                { "required": ["component"] },
                { "required": ["variant"] }
              ]
            }
          },
          {
            "required": ["box"],
            "not": {
              "anyOf": [
                { "required": ["path"] },
                { "required": ["url"] },
                { "required": ["sha256"] },
                { "required": ["github"] },
                { "required": ["package"] },
                { "required": ["version"] },
                { "required": ["git"] },
                { "required": ["commit"] },
                { "required": ["component"] },
                { "required": ["variant"] }
              ]
            }
          },
          {
            "required": ["url", "sha256"],
            "not": {
              "anyOf": [
                { "required": ["path"] },
                { "required": ["box"] },
                { "required": ["github"] },
                { "required": ["package"] },
                { "required": ["version"] },
                { "required": ["git"] },
                { "required": ["commit"] },
                { "required": ["component"] },
                { "required": ["variant"] }
              ]
            }
          },
          {
            "required": ["github", "version"],
            "not": {
              "anyOf": [
                { "required": ["path"] },
                { "required": ["box"] },
                { "required": ["url"] },
                { "required": ["sha256"] },
                { "required": ["git"] },
                { "required": ["commit"] }
              ]
            }
          },
          {
            "required": ["git", "commit"],
            "not": {
              "anyOf": [
                { "required": ["path"] },
                { "required": ["box"] },
                { "required": ["url"] },
                { "required": ["sha256"] },
                { "required": ["github"] },
                { "required": ["package"] },
                { "required": ["version"] },
                { "required": ["component"] },
                { "required": ["variant"] }
              ]
            }
          }
        ]
      }
    },
    "box": {
      "type": "object",
      "description": "Dependency cbox publication settings.",
      "additionalProperties": false,
      "properties": {
        "variants": {
          "type": "array",
          "minItems": 1,
          "description": "Hosted dependency cbox variants. Each variant selects matching dependency/build profiles and appends its suffix to the cbox filename.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["profile"],
            "properties": {
              "profile": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_.-]+$",
                "description": "Dependency/build profile selected for this cbox variant."
              },
              "suffix": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_.-]+$",
                "description": "Filename suffix inserted before the target or ho suffix. Defaults to profile when omitted."
              }
            }
          }
        }
      }
    },
    "profile": {
      "type": "object",
      "description": "Named dependency and build-setting overrides selected with --profile=<name>.",
      "propertyNames": {
        "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "minProperties": 1,
        "properties": {
          "dependencies": {
            "$ref": "#/properties/dependencies"
          },
          "build": {
            "type": "object",
            "additionalProperties": false,
            "minProperties": 1,
            "properties": {
              "configuration": {
                "type": "string",
                "minLength": 1
              },
              "cpp_std": {
                "type": "integer",
                "enum": [11, 14, 17, 20, 23, 26]
              },
              "include_dirs": {
                "$ref": "#/$defs/projectPaths"
              },
              "macos_system_include_dirs": {
                "$ref": "#/$defs/paths"
              },
              "linux_system_include_dirs": {
                "$ref": "#/$defs/paths"
              },
              "windows_system_include_dirs": {
                "$ref": "#/$defs/paths"
              },
              "macos_system_library_dirs": {
                "$ref": "#/$defs/paths"
              },
              "linux_system_library_dirs": {
                "$ref": "#/$defs/paths"
              },
              "windows_system_library_dirs": {
                "$ref": "#/$defs/paths"
              },
              "defines": {
                "$ref": "#/$defs/compileDefinitions"
              }
            }
          }
        }
      }
    },
    "import": {
      "type": "object",
      "description": "Target-specific local artifacts packaged by an imported_library project.",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^(windows|macos|linux)-(x86|x86_64|arm64)$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "public_headers",
          "compiler",
          "compiler_version",
          "cpp_std",
          "configuration",
          "runtime"
        ],
        "properties": {
          "compiler": {
            "type": "string",
            "minLength": 1,
            "description": "CMake compiler identifier used to build the imported binaries."
          },
          "compiler_version": {
            "type": "string",
            "minLength": 1,
            "description": "Exact compiler version used to build the imported binaries."
          },
          "cpp_std": {
            "type": "integer",
            "enum": [11, 14, 17, 20, 23, 26],
            "description": "C++ language standard used to build the imported binaries."
          },
          "configuration": {
            "type": "string",
            "enum": ["Debug", "Release", "RelWithDebInfo", "MinSizeRel"],
            "description": "Build configuration used for the imported binaries."
          },
          "runtime": {
            "type": "string",
            "minLength": 1,
            "description": "Compiler runtime identity used by the imported binaries."
          },
          "public_headers": {
            "$ref": "#/$defs/projectPaths",
            "minItems": 1,
            "description": "Project-relative header files or directory roots mapped under include/."
          },
          "static_libraries": {
            "$ref": "#/$defs/projectPaths",
            "minItems": 1,
            "description": "Project-relative precompiled static libraries mapped under lib/."
          },
          "dynamic_libraries": {
            "$ref": "#/$defs/projectPaths",
            "minItems": 1,
            "description": "Project-relative dynamic-library runtime files mapped under runtime/."
          },
          "import_libraries": {
            "$ref": "#/$defs/projectPaths",
            "minItems": 1,
            "description": "Project-relative Windows import libraries mapped under lib/."
          }
        },
        "anyOf": [
          {
            "required": ["static_libraries"]
          },
          {
            "required": ["dynamic_libraries"]
          },
          {
            "required": ["import_libraries"]
          }
        ]
      }
    },
    "runtime": {
      "type": "object",
      "description": "Project-owned files and directories staged beside this executable or exported from this library.",
      "additionalProperties": false,
      "required": [
        "files"
      ],
      "properties": {
        "files": {
          "$ref": "#/$defs/runtimeFiles",
          "description": "Project-relative runtime assets copied after executable builds and releases, or exported transitively by library boxes, optionally mapped to a different destination."
        }
      }
    },
    "release": {
      "type": "object",
      "description": "Additional project files and directories included in application releases.",
      "additionalProperties": false,
      "properties": {
        "files": {
          "$ref": "#/$defs/projectPaths",
          "description": "Project-relative files and directories copied into the release archive."
        },
        "bundle_name": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+$",
          "description": "Filename-safe base name for multi-executable hosted release bundles. Defaults to the first published library/header target name, then the project name."
        },
        "variants": {
          "type": "array",
          "minItems": 1,
          "description": "Hosted executable release variants. Each variant selects matching dependency/build profiles and appends its suffix to staged executable names.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["profile"],
            "properties": {
              "profile": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_.-]+$",
                "description": "Dependency/build profile selected for this release variant."
              },
              "suffix": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_.-]+$",
                "description": "Filename suffix appended to each executable. Defaults to profile when omitted."
              }
            }
          }
        },
        "readme": {
          "type": "object",
          "description": "Platform-specific README files copied into executable release archives as README.txt.",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "linux": {
              "$ref": "#/$defs/projectPath",
              "description": "Project-relative README copied into Linux executable release archives."
            },
            "macos": {
              "$ref": "#/$defs/projectPath",
              "description": "Project-relative README copied into macOS executable release archives."
            },
            "windows": {
              "$ref": "#/$defs/projectPath",
              "description": "Project-relative README copied into Windows executable release archives."
            }
          }
        },
        "build_number_format": {
          "type": "string",
          "enum": ["semver", "dotted"],
          "description": "Include build.number in generated and extracted release-note headings as version+build.number or version.number."
        }
      }
    },
    "version_header": {
      "type": "object",
      "description": "C/C++ version header regenerated by forge bump.",
      "additionalProperties": false,
      "required": ["path", "prefix"],
      "properties": {
        "path": {
          "$ref": "#/$defs/projectPath",
          "description": "Project-relative generated header path."
        },
        "prefix": {
          "type": "string",
          "pattern": "^[A-Z_][A-Z0-9_]*$",
          "description": "Macro prefix used for generated VERSION_STR, VERSION_MAJOR, VERSION_MINOR, VERSION_PATCH, and VERSION_BUILD definitions."
        }
      }
    }
  },
  "oneOf": [
    {
      "properties": {
        "project": {
          "required": ["type"]
        }
      },
      "not": {
        "required": ["target"]
      }
    },
    {
      "required": ["target"],
      "properties": {
        "project": {
          "not": {
            "required": ["type"]
          }
        }
      },
      "not": {
        "anyOf": [
          {
            "required": ["sources"]
          },
          {
            "required": ["runtime"]
          },
          {
            "required": ["import"]
          }
        ]
      }
    }
  ],
  "allOf": [
    {
      "if": {
        "required": [
          "runtime"
        ]
      },
      "then": {
        "properties": {
          "project": {
            "properties": {
              "type": {
                "const": "executable"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "not": {
                  "const": "imported_library"
                }
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "project": {
            "required": [
              "cpp_std"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "const": "executable"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "required": [
          "sources"
        ],
        "properties": {
          "sources": {
            "type": "object",
            "properties": {
              "paths": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "const": "static_library"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "required": [
          "sources"
        ],
        "properties": {
          "sources": {
            "type": "object",
            "required": [
              "public_headers"
            ],
            "properties": {
              "paths": {
                "type": "array",
                "minItems": 1
              },
              "public_headers": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "enum": [
                  "dynamic_library",
                  "shared_library"
                ]
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "required": [
          "sources"
        ],
        "properties": {
          "sources": {
            "type": "object",
            "required": [
              "public_headers"
            ],
            "properties": {
              "paths": {
                "type": "array",
                "minItems": 1
              },
              "public_headers": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "const": "header_only"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "required": [
          "sources"
        ],
        "properties": {
          "sources": {
            "type": "object",
            "required": [
              "public_headers"
            ],
            "properties": {
              "paths": {
                "type": "array",
                "maxItems": 0
              },
              "public_headers": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "const": "imported_library"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "required": [
          "import"
        ],
        "not": {
          "required": [
            "sources"
          ]
        }
      }
    }
  ],
  "$defs": {
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$",
      "description": "A relative path that remains inside the project."
    },
    "projectPaths": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projectPath"
      },
      "uniqueItems": true
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "paths": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/path"
      },
      "uniqueItems": true
    },
    "platformTarget": {
      "type": "string",
      "enum": [
        "linux-x86_64",
        "linux-arm64",
        "macos-x86_64",
        "macos-arm64",
        "windows-x86",
        "windows-x86_64",
        "windows-arm64"
      ]
    },
    "runtimeFiles": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/projectPath"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source",
              "destination"
            ],
            "properties": {
              "source": {
                "$ref": "#/$defs/projectPath"
              },
              "destination": {
                "$ref": "#/$defs/projectPath"
              }
            }
          }
        ]
      }
    },
    "compileDefinitions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*(?:=[^;\\r\\n]*)?$"
      },
      "uniqueItems": true
    },
    "linkNames": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_.+-]+$"
      },
      "uniqueItems": true
    },
    "publicHeaders": {
      "type": "array",
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/projectPath"
          },
          {
            "type": "string",
            "pattern": "^include/"
          }
        ]
      },
      "uniqueItems": true,
      "description": "Headers exposed to consumers. Paths must remain under include/."
    }
  }
}
