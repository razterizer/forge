{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/razterizer/forge/main/schemas/forge.recipe.schema.json",
  "title": "Forge recipe",
  "description": "Describes a C++ project built, imported, and packaged by Forge.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project"
  ],
  "properties": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$",
          "description": "Package and output artifact name."
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
          "description": "Semantic package version. Artifact build metadata belongs in build.number."
        },
        "type": {
          "type": "string",
          "enum": [
            "executable",
            "static_library",
            "dynamic_library",
            "shared_library",
            "imported_library",
            "header_only"
          ],
          "description": "Kind of project Forge builds or imports and packages. shared_library is a legacy alias for dynamic_library."
        },
        "cpp_std": {
          "type": "integer",
          "enum": [
            11,
            14,
            17,
            20,
            23,
            26
          ],
          "description": "C++ language standard Forge uses to build this project. Compiled boxes record it separately as toolchain metadata for compatibility checks."
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional artifact build number, represented as SemVer build metadata."
        }
      }
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "paths"
      ],
      "properties": {
        "paths": {
          "$ref": "#/$defs/projectPaths",
          "description": "C++ compilation units belonging to the project."
        },
        "public_headers": {
          "$ref": "#/$defs/publicHeaders"
        }
      }
    },
    "dependencies": {
      "type": "object",
      "description": "Local project, local cbox, downloadable cbox, or GitHub Release cbox dependencies.",
      "propertyNames": {
        "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Path to a local Forge project, relative to this recipe or absolute."
          },
          "box": {
            "type": "string",
            "minLength": 1,
            "description": "Path to a local cbox file, relative to this recipe or absolute."
          },
          "url": {
            "type": "string",
            "format": "uri",
            "minLength": 1,
            "description": "URL of a downloadable cbox file."
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$",
            "description": "Expected SHA-256 checksum of the downloaded cbox file."
          },
          "github": {
            "type": "string",
            "pattern": "^[^/\\\\]+/[^/\\\\]+$",
            "description": "GitHub repository containing Forge release assets, in owner/repository form."
          },
          "version": {
            "type": "string",
            "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+build\\.(0|[1-9][0-9]*))?$",
            "description": "Packaged dependency version to resolve from the GitHub release."
          }
        },
        "oneOf": [
          {
            "required": ["path"]
          },
          {
            "required": ["box"]
          },
          {
            "required": ["url", "sha256"]
          },
          {
            "required": ["github", "version"]
          }
        ]
      }
    },
    "import": {
      "type": "object",
      "description": "Target-specific local artifacts packaged by an imported_library project.",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^(windows|macos|linux)-(x86|x86_64|arm64)$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "public_headers",
          "compiler",
          "compiler_version",
          "cpp_std",
          "configuration",
          "runtime"
        ],
        "properties": {
          "compiler": {
            "type": "string",
            "minLength": 1,
            "description": "CMake compiler identifier used to build the imported binaries."
          },
          "compiler_version": {
            "type": "string",
            "minLength": 1,
            "description": "Exact compiler version used to build the imported binaries."
          },
          "cpp_std": {
            "type": "integer",
            "enum": [11, 14, 17, 20, 23, 26],
            "description": "C++ language standard used to build the imported binaries."
          },
          "configuration": {
            "type": "string",
            "enum": ["Debug", "Release", "RelWithDebInfo", "MinSizeRel"],
            "description": "Build configuration used for the imported binaries."
          },
          "runtime": {
            "type": "string",
            "minLength": 1,
            "description": "Compiler runtime identity used by the imported binaries."
          },
          "public_headers": {
            "$ref": "#/$defs/projectPaths",
            "minItems": 1,
            "description": "Project-relative header files or directory roots mapped under include/."
          },
          "static_libraries": {
            "$ref": "#/$defs/projectPaths",
            "minItems": 1,
            "description": "Project-relative precompiled static libraries mapped under lib/."
          },
          "dynamic_libraries": {
            "$ref": "#/$defs/projectPaths",
            "minItems": 1,
            "description": "Project-relative dynamic-library runtime files mapped under runtime/."
          },
          "import_libraries": {
            "$ref": "#/$defs/projectPaths",
            "minItems": 1,
            "description": "Project-relative Windows import libraries mapped under lib/."
          }
        },
        "anyOf": [
          {
            "required": ["static_libraries"]
          },
          {
            "required": ["dynamic_libraries"]
          },
          {
            "required": ["import_libraries"]
          }
        ]
      }
    },
    "release": {
      "type": "object",
      "description": "Additional project files and directories included in application releases.",
      "additionalProperties": false,
      "properties": {
        "files": {
          "$ref": "#/$defs/projectPaths",
          "description": "Project-relative files and directories copied into the release archive."
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "not": {
                  "const": "imported_library"
                }
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "project": {
            "required": [
              "cpp_std"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "const": "executable"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "required": [
          "sources"
        ],
        "properties": {
          "sources": {
            "type": "object",
            "properties": {
              "paths": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "const": "static_library"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "required": [
          "sources"
        ],
        "properties": {
          "sources": {
            "type": "object",
            "required": [
              "public_headers"
            ],
            "properties": {
              "paths": {
                "type": "array",
                "minItems": 1
              },
              "public_headers": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "enum": [
                  "dynamic_library",
                  "shared_library"
                ]
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "required": [
          "sources"
        ],
        "properties": {
          "sources": {
            "type": "object",
            "required": [
              "public_headers"
            ],
            "properties": {
              "paths": {
                "type": "array",
                "minItems": 1
              },
              "public_headers": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "const": "header_only"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "required": [
          "sources"
        ],
        "properties": {
          "sources": {
            "type": "object",
            "required": [
              "public_headers"
            ],
            "properties": {
              "paths": {
                "type": "array",
                "maxItems": 0
              },
              "public_headers": {
                "type": "array",
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "project": {
            "type": "object",
            "properties": {
              "type": {
                "const": "imported_library"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "required": [
          "import"
        ],
        "not": {
          "required": [
            "sources"
          ]
        }
      }
    }
  ],
  "$defs": {
    "projectPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$)).+$",
      "description": "A relative path that remains inside the project."
    },
    "projectPaths": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projectPath"
      },
      "uniqueItems": true
    },
    "publicHeaders": {
      "type": "array",
      "items": {
        "allOf": [
          {
            "$ref": "#/$defs/projectPath"
          },
          {
            "type": "string",
            "pattern": "^include/"
          }
        ]
      },
      "uniqueItems": true,
      "description": "Headers exposed to consumers. Paths must remain under include/."
    }
  }
}
