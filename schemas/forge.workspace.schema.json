{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/razterizer/forge/main/schemas/forge.workspace.schema.json",
  "title": "Forge workspace",
  "description": "Groups independently defined Forge projects into one buildable workspace.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workspace"
  ],
  "properties": {
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "projects"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\.{1,2}$)[^/\\\\]+$",
          "description": "Human-readable workspace name."
        },
        "projects": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Workspace-relative directories containing forge.recipe.toml files."
        }
      }
    }
  }
}
